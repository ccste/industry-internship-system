	"item": [
		{
			"name": "Student log in successful (8 characters Password)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Assert that the response status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"pm.test(\"Response Body contains auth_key\", function () {\r",
							"    pm.expect(pm.response.text()).to.include(\"auth_key\");\r",
							"});\r",
							"\r",
							"pm.test(\"Response Body contains profile_data\", function () {\r",
							"    pm.expect(pm.response.text()).to.include(\"profile_data\");\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
