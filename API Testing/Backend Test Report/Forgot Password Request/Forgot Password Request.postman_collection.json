	"item": [
		{
			"name": "Testing email that has been registered and verified successfully before",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Assert that the response status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"pm.test(\"Response Body contains server_ref\", function () {\r",
							"    pm.expect(pm.response.text()).to.include(\"server_ref\");\r",
							"});\r",
							"\r",
							"pm.test(\"Assert that the value of description is 'Password reset OTP sent'\", function () {\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.description).to.eql(\"Password reset OTP sent\");\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"email\": \"haolix18@student.wintec.ac.nz\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://10.150.2.100:7001/api/forgotPassRequest/",
					"protocol": "http",
					"host": [
						"10",
						"150",
						"2",
						"100"
					],
					"port": "7001",
					"path": [
						"api",
						"forgotPassRequest",
						""
					]
				}
			},
			"response": []
		},
