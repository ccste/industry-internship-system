		{
			"name": "OTP has expired",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Assert that the response status code is 410\", function () {\r",
							"    pm.response.to.have.status(410);\r",
							"});\r",
							"\r",
							"pm.test(\"Assert that the value of error is 'Invalid OTP. OTP has expired'\", function () {\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.error).to.eql(\"Invalid OTP. OTP has expired\");\r",
